TASK_TRACKER=jira
TRACKER_API_KEY=...
TRACKER_BASE_URL=https://your-org.atlassian.net
TRACKER_PROJECT=PROJ
TRACKER_LABEL=codehephaestus
TRACKER_EMAIL=you@org.com

# Jira status mapping (match your workflow)
JIRA_STATUS_TODO=To Do
JIRA_STATUS_IN_PROGRESS=In Progress
JIRA_STATUS_IN_REVIEW=In Review
JIRA_STATUS_DONE=Done

POLL_INTERVAL=120
MAX_ITERATIONS=0
TOOL=claude
TARGET_REPO_PATH=.
WORKTREE_PATH=/tmp/codehephaestus-worktrees
