# --- Branding ---
BOT_DISPLAY_NAME=CodeHephaestus

# --- Tracker ---
TASK_TRACKER=jira                          # "jira" or "linear"
TRACKER_API_KEY=
TRACKER_BASE_URL=https://org.atlassian.net
TRACKER_PROJECT=PROJ

# --- Status Mapping (Jira) ---
JIRA_EMAIL=you@org.com
JIRA_PLANNING_LABEL=codehephaestus
JIRA_APPROVAL_LABEL=approved
JIRA_STATUS_TODO=To Do
JIRA_STATUS_IN_PROGRESS=In Progress
JIRA_STATUS_IN_REVIEW=In Review
JIRA_STATUS_DONE=Done

# --- Status Mapping (Linear) ---
# LINEAR_STATUS_TODO=Todo
# LINEAR_STATUS_IN_PROGRESS=In Progress
# LINEAR_STATUS_IN_REVIEW=In Review
# LINEAR_STATUS_DONE=Done

# --- Claude Code ---
CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS=1
TEAM_LEAD_MODEL=opus
TEAMMATE_MODEL=sonnet
PLANNING_MODEL=sonnet

# --- Planning ---
# Planning follows two phases: Product Requirements Refinement → Technical Refinement.
# Product phase focuses on what to build (user stories, acceptance criteria, edge cases).
# Technical phase focuses on how to build it (architecture, data models, APIs).
PLANNING_REMINDER_DAYS=7
PLANNING_TIMEOUT_ACTION=remind             # "remind" or "abandon"
# AUTO_LAUNCH_IMPLEMENTATION=true          # When true, skip the human ready signal and
                                           # auto-launch implementation once both planning
                                           # phases are complete and the ticket is assigned
                                           # to the bot. Default: false (require ready signal).

# --- Figma (optional) ---
# FIGMA_ACCESS_TOKEN=
FIGMA_EXPORT_SCALE=2
FIGMA_EXPORT_FORMAT=png

# --- Implementation ---
MAX_REVIEW_ROUNDS=3
MAX_CI_FIX_ATTEMPTS=5
MAX_UAT_RETRIES=3
AGENT_TEAM_TIMEOUT=3600

# --- Runtime ---
POLL_INTERVAL=120
MAX_ITERATIONS=0                           # 0 = infinite
TARGET_REPO_PATH=.
# WORKTREE_PATH=                           # Default: {TARGET_REPO_PATH}/.worktrees/
# STATE_DB_PATH=                           # Default: {TARGET_REPO_PATH}/.codehephaestus/state.db

# --- Logging ---
LOG_LEVEL=info
